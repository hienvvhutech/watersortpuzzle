rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profile rules: Anyone can read, only the profile owner can write
    match /profiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Leaderboard rules: Anyone can read, only the entry owner can write
    match /leaderboards/{seasonId}/entries/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Group rules: Members can read, creator can modify
    match /groups/{groupId} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }
    
    // Subcollection: Group members
    match /groups/{groupId}/members/{memberUid} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      allow write: if request.auth != null && (request.auth.uid == memberUid || get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid);
    }

    // Friend requests: sender or recipient can read; only sender can create; only recipient can update status
    match /friendRequests/{requestId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow delete: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    // Battle invites: sender or recipient can read/update; only sender can create
    match /battleInvites/{inviteId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }
  }
}
